# ── Copy this file to .env and fill in the values ──────────────

# App
DEBUG=false
LOG_LEVEL=INFO

# Database — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite+aiosqlite:///./handtalk.db
# DATABASE_URL=postgresql+asyncpg://handtalk:password@db:5432/handtalk

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Recognition model path (leave default unless you moved it)
ONNX_MODEL_PATH=ml/models/sign_recognizer.onnx

# Camera (0 = built-in laptop webcam)
CAMERA_INDEX=0

# Glove — set USE_MOCK_GLOVE=false once the real ESP32 is connected
USE_MOCK_GLOVE=true
MOCK_GLOVE_HZ=50

# CORS — add your client origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:5500"]
